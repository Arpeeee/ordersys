# Django core
SECRET_KEY=django-insecure-changeme-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
# 本地開發：DB_HOST=db (docker compose service name) or localhost (直接跑)
# 生產 (Neon)：DB_HOST=ep-xxx-yyy.region.aws.neon.tech
DB_NAME=coffeedb
DB_USER=taiwannick
DB_PASSWORD=xxx
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=disable

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 媒體檔案
# 留空 = 本地 media/ 目錄
# 填入 bucket name = 上傳到 GCS（生產環境）
GCS_BUCKET_NAME=

# 生產環境 HTTPS 設定（本地留空）
CSRF_TRUSTED_ORIGINS=
